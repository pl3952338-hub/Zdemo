.page {
  padding: 24rpx;
}

.item {
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.04);
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
}

.item-detail {
  color: #7f7f7f;
  margin-top: 6rpx;
}

.item-total {
  margin-top: 12rpx;
  color: #ff5f4d;
}

.link-button {
  margin-top: 12rpx;
  border-color: #ff5f4d;
  color: #ff5f4d;
}

.subtotal-row {
  display: flex;
  justify-content: space-between;
  font-weight: 600;
  align-items: center;
  padding: 0 8rpx;
  margin-bottom: 12rpx;
}

.subtotal-value {
  color: #ff5f4d;
  font-size: 30rpx;
}

.clear-button {
  width: 100%;
  background: #ff5f4d;
  color: #fff;
}

.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #9c9c9c;
  font-size: 28rpx;
}
