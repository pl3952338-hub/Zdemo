.container {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 36rpx;
  box-shadow: 0 18rpx 32rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
}

.meta {
  font-size: 26rpx;
  color: #5c5c5c;
  margin-top: 12rpx;
}

.status,
.note {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2b2b2b;
}

.photo {
  margin-top: 20rpx;
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(31, 45, 61, 0.1);
}

.photo image {
  width: 100%;
  height: 100%;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #9a9a9a;
  font-size: 26rpx;
}
