.page {
  padding: 24rpx;
}

.detail-card {
  background: #fff;
  padding: 26rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 18rpx;
}

.detail-name {
  font-size: 32rpx;
  font-weight: 600;
}

.detail-price {
  color: #ff5f4d;
  font-size: 30rpx;
  margin-top: 12rpx;
}

.detail-stock {
  color: #999;
  margin-top: 10rpx;
}

.detail-desc {
  color: #444;
  margin-top: 18rpx;
  line-height: 38rpx;
}

.buy-button {
  width: 100%;
  background: linear-gradient(120deg, #4f7ff8, #6ddfff);
  color: #fff;
}

.not-found {
  color: #999;
  font-size: 26rpx;
}
