<view class="page">
  <view wx:if="{{product}}" class="detail-card">
    <text class="detail-name">{{product.name}}</text>
    <text class="detail-price">¥{{product.price}}</text>
    <text class="detail-stock">库存：{{product.stock}} 件</text>
    <text class="detail-desc">{{product.detail}}</text>
  </view>
  <view wx:else>
    <text class="not-found">未找到对应商品。</text>
  </view>
  <button class="buy-button" bindtap="addToCart" wx:if="{{product}}">加入购物车</button>
</view>
