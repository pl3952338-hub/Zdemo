.container {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 18rpx 36rpx rgba(18, 24, 41, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.timestamp {
  margin-top: 8rpx;
  color: #7a7a7a;
  font-size: 24rpx;
}

.field {
  margin-top: 24rpx;
}

.label {
  font-size: 24rpx;
  margin-bottom: 10rpx;
  display: block;
  color: #2a2a2a;
}

input,
textarea {
  width: 100%;
  border-radius: 20rpx;
  border: 1rpx solid #e4e4e4;
  padding: 16rpx;
  font-size: 26rpx;
  background: #fcfcfc;
  line-height: 36rpx;
}

textarea {
  min-height: 120rpx;
  resize: none;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

button {
  flex: 1;
  border-radius: 16rpx;
}

.pro {
  background-color: #4f7ff8;
  color: #ffffff;
}

.light {
  border: 1rpx solid #4f7ff8;
  color: #4f7ff8;
  background: #ffffff;
}

.status {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f7f9ff;
}

.status-label {
  font-size: 24rpx;
  color: #4d4d4d;
}

.status-value {
  font-size: 26rpx;
  margin-top: 6rpx;
  color: #1c1c1c;
  word-break: break-all;
}

.photo-preview {
  margin-top: 18rpx;
  width: 100%;
  height: 240rpx;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(31, 45, 61, 0.1);
}

.photo-preview image {
  width: 100%;
  height: 100%;
}

.submit {
  width: 100%;
  margin-top: 26rpx;
  background: linear-gradient(120deg, #4f7ff8, #6bd1ff);
  color: #fff;
  font-size: 28rpx;
  padding: 18rpx 0;
}

.link {
  margin-top: 20rpx;
  width: 100%;
  border: none;
  background: none;
  color: #4f7ff8;
  font-size: 26rpx;
}
