.container {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  padding: 28rpx;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 20rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
}

.meta {
  color: #7b7b7b;
  margin-top: 10rpx;
  font-size: 24rpx;
}

.status {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #1f1f1f;
}

.note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5d5d5d;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}
