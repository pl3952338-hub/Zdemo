<view class="page">
  <view class="hero">
    <text class="hero-title">{{hero.title}}</text>
    <text class="hero-subtitle">{{hero.subtitle}}</text>
  </view>
  <view class="actions">
    <button class="primary" bindtap="gotoProductList">查看商品</button>
    <button class="secondary" bindtap="gotoCart">我的购物车</button>
  </view>
  <view class="section">
    <text class="label">今日推荐</text>
    <view class="card-list">
      <view
        class="card"
        wx:for="{{spotlight}}"
        wx:key="id"
        bindtap="openDetail"
        data-id="{{item.id}}"
      >
        <text class="card-title">{{item.name}}</text>
        <text class="card-sub">{{item.shortDescription}}</text>
        <text class="card-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
  <view class="section">
    <text class="label">平台特点</text>
    <view class="overview">
      <view class="overview-item" wx:for="{{overview}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>
  </view>
</view>
